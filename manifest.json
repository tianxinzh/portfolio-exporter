{
  "manifest_version": 3,
  "name": "Portfolio Exporter",
  "version": "1.0.0",
  "description": "Export your Robinhood holdings (equities, options, crypto) with live prices to CSV, JSON, or YAML. 100% local — nothing leaves your device.",
  "permissions": ["downloads", "storage"],
  "host_permissions": ["*://*.robinhood.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.robinhood.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/interceptor.js"],
      "matches": ["*://*.robinhood.com/*"]
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "Portfolio Exporter",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
